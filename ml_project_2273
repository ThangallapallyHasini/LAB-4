      "source": [
        "def detect_drift(train_data, test_data):\n",
        "\n",
        "    stat, pvalue = ks_2samp(train_data, test_data)\n",
        "\n",
        "    print(\"Drift Test Statistic:\", stat)\n",
        "    print(\"P-value:\", pvalue)\n",
        "\n",
        "    if pvalue < 0.05:\n",
        "        print(\"⚠️ Data Drift Detected\")\n",
        "    else:\n",
        "        print(\"✅ No Data Drift\")\n",
        "\n",
        "detect_drift(y_train, y_test)"
      ],
