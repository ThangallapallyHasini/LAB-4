      "execution_count": null,
      "outputs": []
    },
    {
      "cell_type": "code",
      "source": [
        "def load_data(file_path):\n",
        "    df = pd.read_csv(file_path)\n",
        "    df['timestamp'] = pd.to_datetime(df['timestamp'])\n",
        "    return df\n",
        "\n",
        "data = load_data(\"/content/electricity_train.csv\")\n",
        "\n",
        "print(\"Dataset Shape:\", data.shape)\n",
        "print(data)"
      ],
